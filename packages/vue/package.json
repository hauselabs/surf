{
  "name": "@surfjs/vue",
  "version": "0.1.0",
  "description": "Vue composables for the window.surf runtime — register local handlers, sync state, and surface Surf Live",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@surfjs/web": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vue": "^3.5.0"
  },
  "license": "MIT",
  "keywords": [
    "surf",
    "vue",
    "ai",
    "agents",
    "real-time",
    "websocket",
    "state-sync"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hauselabs/surf.git",
    "directory": "packages/vue"
  },
  "homepage": "https://surf.codes",
  "bugs": {
    "url": "https://github.com/hauselabs/surf/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
