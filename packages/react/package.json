{
  "name": "@surfjs/react",
  "version": "0.4.2",
  "description": "React SDK for Surf Live — real-time state sync between AI agents and your UI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "react": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "keywords": [
    "surf",
    "react",
    "ai",
    "agents",
    "real-time",
    "websocket",
    "state-sync"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hauselabs/surf.git",
    "directory": "packages/react"
  },
  "homepage": "https://surf.codes",
  "bugs": {
    "url": "https://github.com/hauselabs/surf/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
