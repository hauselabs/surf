{
  "name": "@surfjs/next",
  "version": "0.2.3",
  "description": "Next.js adapter for Surf.js — App Router + Pages Router support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pages": {
      "import": {
        "types": "./dist/pages.d.ts",
        "default": "./dist/pages.js"
      },
      "require": {
        "types": "./dist/pages.d.cts",
        "default": "./dist/pages.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@surfjs/core": ">=0.2.0",
    "next": ">=13.0.0"
  },
  "devDependencies": {
    "@surfjs/core": "workspace:*",
    "@types/node": "^22.0.0",
    "next": "^15.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "keywords": [
    "surf",
    "next",
    "nextjs",
    "ai",
    "agents",
    "protocol",
    "app-router",
    "pages-router"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hauselabs/surf.git",
    "directory": "packages/next"
  },
  "homepage": "https://surf.codes",
  "bugs": {
    "url": "https://github.com/hauselabs/surf/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
