{
  "name": "@surfjs/client",
  "version": "0.3.6",
  "description": "Agent-side client SDK for Surf-enabled sites and apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "ws": "^8.18.0",
    "@types/ws": "^8.5.0"
  },
  "license": "MIT",
  "keywords": [
    "surf",
    "ai",
    "agents",
    "client",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hauselabs/surf.git",
    "directory": "packages/client"
  },
  "homepage": "https://surf.codes",
  "bugs": {
    "url": "https://github.com/hauselabs/surf/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
