{
  "name": "@surfjs/web",
  "version": "0.5.2",
  "description": "Framework-agnostic window.surf local execution runtime for Surf-enabled websites",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "keywords": [
    "surf",
    "ai",
    "agents",
    "browser",
    "runtime",
    "window.surf"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hauselabs/surf.git",
    "directory": "packages/web"
  },
  "homepage": "https://surf.codes",
  "bugs": {
    "url": "https://github.com/hauselabs/surf/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
